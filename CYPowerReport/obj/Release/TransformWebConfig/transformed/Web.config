<configuration>
  <!--
    如需 web.config 變更的說明，請參閱 http://go.microsoft.com/fwlink/?LinkId=235367。

    您可以在 <httpRuntime> 標記上設定下列屬性。
      <system.Web>
        <httpRuntime targetFramework="4.5.2" />
      </system.Web>
  -->
  <system.web>
    <httpHandlers>
      <add path="ChartImg.axd" verb="GET,HEAD,POST" type="System.Web.UI.DataVisualization.Charting.ChartHttpHandler, System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" validate="false" />
    </httpHandlers>
    <compilation targetFramework="4.5.2">
      <assemblies>
        <add assembly="System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" />
      </assemblies>
    </compilation>
    <pages controlRenderingCompatibilityVersion="4.0">
      <controls>
        <add tagPrefix="uc" tagName="Pager" src="~/_uc/ucPager.ascx" />
        <add tagPrefix="uc" tagName="YesNo" src="~/_uc/ucYesNo.ascx" />
        <add tagPrefix="uc" tagName="ucDate" src="~/_uc/ucDate.ascx" />
        <add tagPrefix="uc" tagName="ucDept" src="~/_uc/ucDept.ascx" />
        <add tagPrefix="asp" namespace="System.Web.UI.DataVisualization.Charting" assembly="System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      </controls>
    </pages>
    <authentication mode="Forms" />
    <sessionState timeout="480" />
    <httpRuntime enableVersionHeader="false" maxRequestLength="20480" executionTimeout="300" targetFramework="4.5.2" />
    <trace enabled="false" localOnly="true" />
    <customErrors mode="RemoteOnly" redirectMode="ResponseRewrite" defaultRedirect="~/error/error.html" />
    <webServices>
      <protocols>
        <add name="HttpPost" />
      </protocols>
    </webServices>
  </system.web>
  <connectionStrings>
    <clear />
    <add connectionString="Data Source=220.134.173.183,2433;Initial Catalog=CYPowerReportDB;User ID=solargo;Password=bHaNdyA2P7mf" name="Main" providerName="System.Data.SqlClient" />
    <!--<add connectionString="Data Source=chunyoung.asuscomm.com,4513;Initial Catalog=CYPowerReportDB;User ID=sa;Password=P@ssw0rd" name="Main" providerName="System.Data.SqlClient" />-->
  </connectionStrings>
  <system.webServer>
    <httpErrors errorMode="DetailedLocalOnly" />
    <defaultDocument>
      <files>
        <add value="login.aspx" />
        <add value="index.aspx" />
        <add value="index.ashx" />
      </files>
    </defaultDocument>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20980000" />
      </requestFiltering>
    </security>
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
    <validation validateIntegratedModeConfiguration="false" />
    <handlers>
      <remove name="ChartImageHandler" />
      <add name="ChartImageHandler" preCondition="integratedMode" verb="GET,HEAD,POST" path="ChartImg.axd" type="System.Web.UI.DataVisualization.Charting.ChartHttpHandler, System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
    </handlers>
  </system.webServer>
  <appSettings>
    <!--CSV檔案路徑-->
    <add key="FTP_BILLION" value="D:\FTP\LocalUser\FTP_BILLION\" />
    <add key="FTP_BIGSUN" value="D:\FTP\LocalUser\FTP_BIGSUN\" />
    <add key="FTP_HUAWEI" value="D:\FTP\LocalUser\FTP_HUAWEI\FTP_HUAWEI\" />
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="none" />
    <!--宇軒-自動匯入-->
    <add key="DoAutoImport" value="0" />
    <!--報表-->
    <add key="DoAuto" value="0" />
    <add key="DoMapp" value="0" />
    <add key="SyncMappSP" value="" />
    <!--每10秒同步Mapp資料，執行的SP，如果不執行 將value改空白-->
    <add key="FileAllow" value=".xls|.xlsx|.xlt|.xlsm" />
    <add key="TemplatePath" value="C:\Projects\CYCloudReport\CYCloudReport\ReportTemplate\" />
    <add key="ReportStorePath" value="D:\ReportFiles\000\" />
    <add key="ChartImageHandler" value="storage=file;timeout=20;dir=c:\TempImageFiles\;" />
    <add key="SyncValueExtCount" value="100" />
    <!--辨識系統辨識結果查詢API，如不執行，value保留空白 http://192.168.1.150:8000/si/std/log/user/query  -->
    <add key="RecognitionAuth" value="" />
    <!--<add key="SyncRecognitionAuthInterval" value="* * * ? * * *" />-->
    <add key="SyncRecognitionAuthInterval" value="0/10 * * ? * * *" />
    <!--辨識系統-時間差設定，避免系統間時間誤差，如不輸入或輸入錯誤，預設為5分鐘-->
    <add key="RecognitionDiffMinutes" value="5" />
    <!--廠商資料同步至辨識系統API路徑，如不執行，value保留空白 http://192.168.1.150:8000/si/std/ -->
    <add key="RecognitionPath" value="" />
    <!--廠商資料同步至辨識系統API DeviceName-->
    <add key="DeviceName" value="BR06E" />
    <!--廠商資料同步至辨識系統API ResultLog 1 or 0-->
    <add key="ResultLog" value="0" />
    <!--廠商資料同步至辨識系統API Account-->
    <add key="RecognitionAccount" value="admin@tw.shuttle.com" />
    <!--廠商資料同步至辨識系統API Password-->
    <add key="RecognitionPassword" value="password" />
    <!--廠商資料同步至辨識系統API MAC值-->
    <add key="RecognitionMAC" value="08-9E-01-4C-6A-D9" />
    <!--DoCheckProject：是否啟動[自動資料檢核]，如是value填入1-->
    <add key="DoCheckProject" value="0" />
    <!--廠商施工管理 CheckIn用 Device代號 ，多筆資料請用';'隔開-->
    <add key="WorkCheckInDeviceCheckIn" value="CHECKIN;CHECKIN1" />
    <!--廠商施工管理 CheckOut用 Device代號 ，多筆資料請用';'隔開-->
    <add key="WorkCheckInDeviceCheckOut" value="CHECKIN;CHECKIN1" />
    <!--廠商施工管理 辨識專用代號-->
    <add key="WorkCheckInCode" value="IA-05002;IA-07001" />
    <!--廠商施工管理 自動簽退-->
    <add key="WorkAutoCheckOut" value="0" />
    <add key="opcServerIp" value="127.0.0.1" />
    <add key="opcServerName" value="ArchestrA.FSGateway" />
    <add key="opcServerGroup" value="Local_InTouch" />
    <add key="opcUpdateRate" value="5000" />
    <add key="logPath" value="D:/" />
    <add key="oldFFUPerformanceTable" value="vOLDFFUEquipment" />
    <add key="ffuDebug" value="0" />
    <!--警報參數管理-->
    <add key="startAlarmUpdater" value="http://114.35.232.251:8088/AlarmStatusUpdater/api/TagManager/StartUpdater" />
    <add key="stopAlarmUpdater" value="http://114.35.232.251:8088/AlarmStatusUpdater/api/TagManager/StopUpdater" />
    <!--demo-->
    <add key="startOPCOnStart" value="0" />
    <!--更新tag資料-->
    <add key="ForceReadTag" value="0" />
    <add key="ForceReadTagTimeString" value="30 * * ? * * *" />
    <!--寫tag資料入DB-->
    <add key="WriteTag2DB" value="0" />
    <add key="WriteTag2DBTimeString" value="0 * * ? * * *" />
    <!--自動報表-->
    <add key="DemoDoAuto" value="0" />
    <!--授權檔路徑-->
    <add key="LicNo" value="4859535852495555486056457157535977" />
    <add key="ErrLogPath" value="D:\CYPowerReport\" />
  </appSettings>
  <runtime>
